# ═══════════════════════════════════════════════════════════════
# CourseForge AI — Environment Configuration Template
# Copy this file to .env (in the backend/ directory) and fill in values.
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_PORT=8001
APP_SECRET_KEY=change_me_generate_with_python_secrets_token_hex_64

# ─────────────────────────────────────────────
# Database — PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=courseforge
POSTGRES_USER=courseforge_user
POSTGRES_PASSWORD=your_postgres_password_here

# ─────────────────────────────────────────────
# Redis (Celery broker + cache)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────
# Authentication (JWT)
# ─────────────────────────────────────────────
JWT_SECRET_KEY=change_me_generate_with_python_secrets_token_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# InsightForge-AI Integration
# ─────────────────────────────────────────────
INSIGHTFORGE_PATH=/absolute/path/to/InsightForge-AI

# ─────────────────────────────────────────────
# AI — Groq
# ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=50

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_FILE=./logs/courseforge.log
