# ═══════════════════════════════════════════════════════════════
# CourseForge AI — Environment Configuration Template
# Copy this file to .env (in the backend/ directory) and fill in values.
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
# Purpose: Defines the environment the application is running in.
# Allowed values: development, staging, production
# Default: development
# Required: Yes
APP_ENV=development

# Purpose: Enables debug mode, returning detailed stack traces on errors.
# Allowed values: true, false
# Default: true (forced to false in production)
# Required: No
APP_DEBUG=true

# Purpose: The port the backend application runs on.
# Allowed values: integer > 0
# Default: 8001
# Required: No
APP_PORT=8001

# Purpose: A strong cryptographic key for signing session cookies and app-level security.
# Allowed values: string of at least 32 characters
# Example: 7a92b8d00...
# Required: Yes
# NOTE: "change_me", "password", etc. are strictly rejected.
APP_SECRET_KEY=generate_me_with_python_secrets_token_hex_64

# Purpose: Enable Swagger UI and ReDoc.
# Allowed values: true, false
# Default: true (forced to false in production)
# Required: No
ENABLE_DOCS=true

# ─────────────────────────────────────────────
# Database — PostgreSQL
# ─────────────────────────────────────────────
# Purpose: Database host address.
# Default: localhost
# Required: Yes
POSTGRES_HOST=localhost

# Purpose: Database port.
# Default: 5432
# Required: No
POSTGRES_PORT=5432

# Purpose: Database name.
# Default: courseforge
# Required: Yes
POSTGRES_DB=courseforge

# Purpose: Database user.
# Default: courseforge_user
# Required: Yes
POSTGRES_USER=courseforge_user

# Purpose: Database password.
# Allowed values: string (cannot be a placeholder like "password")
# Required: Yes
POSTGRES_PASSWORD=your_secure_postgres_password

# ─────────────────────────────────────────────
# Redis (Celery broker + cache)
# ─────────────────────────────────────────────
# Purpose: Redis host address.
# Default: localhost
# Required: Yes (if Celery is enabled)
REDIS_HOST=localhost

# Purpose: Redis port.
# Default: 6379
# Required: No
REDIS_PORT=6379

# Purpose: Redis password.
# Allowed values: string (cannot be a placeholder like "password")
# Required: No
REDIS_PASSWORD=

# Purpose: Redis database number.
# Default: 0
# Required: No
REDIS_DB=0

# ─────────────────────────────────────────────
# Celery
# ─────────────────────────────────────────────
# Purpose: Timeout for celery background tasks in seconds.
# Allowed values: integer > 0
# Default: 600
# Required: No
CELERY_TASK_TIMEOUT_SECONDS=600

# Purpose: Maximum retries for Celery tasks.
# Allowed values: integer >= 0
# Default: 3
# Required: No
CELERY_MAX_RETRIES=3

# ─────────────────────────────────────────────
# Authentication (JWT)
# ─────────────────────────────────────────────
# Purpose: Cryptographic key for signing JWT tokens.
# Allowed values: string of at least 32 characters
# Example: 7a92b8d00...
# Required: Yes
# NOTE: "change_me", "password", etc. are strictly rejected.
JWT_SECRET_KEY=generate_me_with_python_secrets_token_hex_64

# Purpose: Algorithm used for JWT encoding.
# Default: HS256
# Required: No
JWT_ALGORITHM=HS256

# Purpose: Access token expiry in minutes.
# Default: 30
# Required: No
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Purpose: Refresh token expiry in days.
# Default: 7
# Required: No
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# InsightForge Integration
# ─────────────────────────────────────────────
# Purpose: Optional path to external InsightForge-AI repository override.
# Default: None
# Required: No
# INSIGHTFORGE_PATH=/absolute/path/to/InsightForge-AI

# ─────────────────────────────────────────────
# AI — Groq
# ─────────────────────────────────────────────
# Purpose: API key for Groq LLM inference.
# Required: Yes (min length 10)
GROQ_API_KEY=your_groq_api_key_here

# Purpose: LLM model to use.
# Default: llama-3.3-70b-versatile
# Required: No
GROQ_MODEL=llama-3.3-70b-versatile

# Purpose: Max tokens for Groq response.
# Allowed values: integer > 0
# Default: 2048
# Required: No
GROQ_MAX_TOKENS=2048

# Purpose: LLM generation temperature.
# Allowed values: float between 0.0 and 2.0
# Default: 0.2
# Required: No
GROQ_TEMPERATURE=0.2

# Purpose: Timeout in seconds for LLM API requests.
# Allowed values: integer > 0
# Default: 60
# Required: No
GROQ_REQUEST_TIMEOUT_SECONDS=60

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
# Purpose: Allowed origins for Cross-Origin Resource Sharing.
# Required: No
# NOTE: In production, wildcard (*) and localhost are rejected.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────────
# Purpose: Directory where uploaded files are stored.
# Default: ./uploads
# Required: No
UPLOAD_DIR=./uploads

# Purpose: Directory where exported courses are stored.
# Default: ./exports
# Required: No
EXPORT_DIR=./exports

# Purpose: Maximum allowed upload file size in megabytes.
# Allowed values: integer > 0
# Default: 50
# Required: No
MAX_UPLOAD_SIZE_MB=50

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
# Purpose: Logging severity level.
# Allowed values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# Required: No
LOG_LEVEL=INFO

# Purpose: Logging output format.
# Allowed values: text, json
# Default: json
# Required: No
LOG_FORMAT=text

# Purpose: Path to the log file.
# Default: ./logs/courseforge.log
# Required: No
LOG_FILE=./logs/courseforge.log
