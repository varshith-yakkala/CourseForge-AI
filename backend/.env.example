# ===============================================================
# CourseForge AI - Backend Environment Configuration Template
#
# HOW TO USE:
#   cp backend/.env.example backend/.env
#   Fill in all values marked with CHANGE_ME before running.
#
# NEVER commit a .env file containing real credentials.
# Only .env.example belongs in version control.
# ===============================================================

# APPLICATION
APP_ENV=development
APP_DEBUG=true
APP_PORT=8001
APP_SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_64
API_V1_STR=/api/v1
ENABLE_DOCS=true

# DATABASE - PostgreSQL
# Option A: Individual parts (used if DATABASE_URL is not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=courseforge
POSTGRES_USER=courseforge_user
POSTGRES_PASSWORD=CHANGE_ME_your_postgres_password

# Option B: Full connection string (overrides individual parts above)
# Render/Neon provides this as DATABASE_URL. Supports postgres://, postgresql://, postgresql+asyncpg://
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname


# AUTHENTICATION (JWT)

# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI - Groq LLM (https://console.groq.com)
GROQ_API_KEY=CHANGE_ME_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.2
GROQ_REQUEST_TIMEOUT_SECONDS=60

# INSIGHTFORGE (Optional external RAG engine)
# Leave commented to use the bundled internal adapter.
# INSIGHTFORGE_PATH=/absolute/path/to/InsightForge-AI

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true

# FILE STORAGE
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.md

# LOGGING
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_FILE=./logs/courseforge.log

# RATE LIMITING
RATE_LIMIT_CHAT_MESSAGES_PER_HOUR=60
RATE_LIMIT_UPLOAD_PER_DAY=10
