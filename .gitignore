# ─────────────────────────────────────────────
# Environment / Secrets — NEVER COMMIT REAL CREDENTIALS
# ─────────────────────────────────────────────
# Ignore all real environment files with credentials
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# But keep example/template files tracked so developers know what vars are needed
!.env.example
!**/.env.example
